# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/keys

# Production: Set this environment variable on your deployment platform
# For local development: Create .env.local file with your actual key
VITE_OPENROUTER_API_KEY=your_api_key_here

# Optional: API endpoint override (defaults to https://openrouter.ai/api/v1/chat/completions)
# VITE_OPENROUTER_API_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
